{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:component",
    "component": "buckets_update:oxidation_stage",
    "cases": [
      {"when": "exposed",   "model": {"type": "minecraft:model", "model": "buckets_update:item/waxed_copper_water_bucket_exposed"}},
      {"when": "weathered", "model": {"type": "minecraft:model", "model": "buckets_update:item/waxed_copper_water_bucket_weathered"}},
      {"when": "oxidized",  "model": {"type": "minecraft:model", "model": "buckets_update:item/waxed_copper_water_bucket_oxidized"}}
    ],
    "fallback": {"type": "minecraft:model", "model": "buckets_update:item/waxed_copper_water_bucket"}
  }
}
